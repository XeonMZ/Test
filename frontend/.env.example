# URL publik backend Laravel, DIAKHIRI dengan /api
# WAJIB diset di Railway (service frontend) SEBELUM build, karena Next.js
# membakar variabel NEXT_PUBLIC_* saat build — bukan saat runtime.
# Setelah mengubah nilai ini, WAJIB redeploy/rebuild frontend.
#
# Contoh: NEXT_PUBLIC_API_URL=https://sjt-backend.up.railway.app/api
NEXT_PUBLIC_API_URL=

# (Opsional) URL WebSocket Reverb untuk realtime, bila dipakai.
# NEXT_PUBLIC_REVERB_HOST=
# NEXT_PUBLIC_REVERB_PORT=443
# NEXT_PUBLIC_REVERB_SCHEME=https
