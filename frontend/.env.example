# URL publik backend Laravel, DIAKHIRI dengan /api.
# WAJIB diset di environment hosting SEBELUM build, karena Next.js membakar
# variabel NEXT_PUBLIC_* saat build — bukan saat runtime. Setelah mengubah
# nilai ini, WAJIB rebuild/redeploy frontend.
#
# Contoh: NEXT_PUBLIC_API_URL=https://api.example.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# URL publik situs frontend ini (dipakai untuk metadata, sitemap, robots).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# (Opsional) URL WebSocket Reverb untuk realtime, bila dipakai.
# NEXT_PUBLIC_REVERB_APP_KEY=
# NEXT_PUBLIC_REVERB_HOST=
# NEXT_PUBLIC_REVERB_PORT=443
# NEXT_PUBLIC_REVERB_SCHEME=https
