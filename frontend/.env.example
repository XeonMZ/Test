# ─────────────────────────────────────────────────────────────────────────────
# URL API — DUA CARA, pilih salah satu
# ─────────────────────────────────────────────────────────────────────────────
#
# CARA 1 (DISARANKAN) — API_URL, dibaca saat RUNTIME.
# Ubah nilainya lalu cukup RESTART service frontend. TIDAK perlu rebuild.
# Nilai ini disuntikkan server ke halaman dan dipakai oleh browser.
#
#   API_URL=https://api.domain-anda.com/api
#
API_URL=

# CARA 2 — NEXT_PUBLIC_API_URL, dibakar saat BUILD.
# Next.js menyalin variabel NEXT_PUBLIC_* ke dalam bundel ketika `next build`
# dijalankan. Mengubahnya di panel hosting TIDAK berpengaruh sampai frontend
# di-REBUILD. Inilah penyebab umum error "Network Error" di production:
# bundel masih memanggil http://localhost:8000/api dari perangkat pengguna.
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# URL publik situs frontend ini (dipakai untuk metadata, sitemap, robots).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# (Opsional) URL WebSocket Reverb untuk realtime, bila dipakai.
# NEXT_PUBLIC_REVERB_APP_KEY=
# NEXT_PUBLIC_REVERB_HOST=
# NEXT_PUBLIC_REVERB_PORT=443
# NEXT_PUBLIC_REVERB_SCHEME=https
