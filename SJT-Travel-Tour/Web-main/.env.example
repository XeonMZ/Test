# Used by docker-compose.yml to bake NEXT_PUBLIC_* values into the frontend
# build. Next.js inlines these at BUILD time, so they must be correct BEFORE
# running `docker compose build` / `docker compose up --build` — changing
# them afterwards requires a rebuild, not just a container restart.
#
# Copy this file to `.env` in the project root and adjust the values for
# your deployment (e.g. real domain/IP instead of localhost) before building.

# Must be reachable from the END USER'S BROWSER (not just from inside Docker).
# Example for a real deployment: https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Realtime (Laravel Reverb) is OFF by default because this docker-compose
# stack does not include a Reverb service. Set to true and fill in the
# Reverb values below only if you run Reverb yourself.
NEXT_PUBLIC_REALTIME_ENABLED=false
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http
NEXT_PUBLIC_REVERB_APP_KEY=

NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_GOOGLE_MAP_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
