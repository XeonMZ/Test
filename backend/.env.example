# =====================================================================
# SJT backend environment. Every deployment-specific value lives here;
# the application code never hardcodes hosts, ports, domains, or secrets.
# =====================================================================

APP_NAME=STMS
# Set to "production" on live deployments. Production disables beta mode,
# enforces the uncompromised-password rule, and hides debug output.
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Public URL of THIS backend service.
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id

# Public URL of the Next.js frontend (used for CORS and password-reset links).
FRONTEND_URL=http://localhost:3000
# Extra allowed CORS origins (comma-separated exact origins).
CORS_ALLOWED_ORIGINS=
# Optional comma-separated regex patterns, e.g. #^https://.*\.example\.com$#
CORS_ALLOWED_ORIGIN_PATTERNS=
# Never enable in production.
CORS_ALLOW_ALL=false

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=stms
DB_USERNAME=root
DB_PASSWORD=

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

CACHE_STORE=file
# PENTING (produksi): aplikasi memakai DELAYED JOBS untuk kedaluwarsa booking &
# pembayaran serta rilis kursi. Dengan "sync" delayed job TIDAK berjalan, sehingga
# kursi yang dikunci tidak pernah dirilis. Di produksi gunakan "database" (butuh
# tabel jobs — sudah ada migrasinya) DAN jalankan: php artisan queue:work
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@stms.test
MAIL_FROM_NAME=STMS

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

# API ini murni bearer-token; mode stateful/CSRF Sanctum TIDAK dipakai.
# JANGAN mengisi SANCTUM_STATEFUL_DOMAINS dengan domain frontend — tidak perlu.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SANCTUM_TOKEN_NAME=stms-api-token
SANCTUM_TOKEN_EXPIRATION=1440

# Frontend page that consumes password-reset tokens.
# Defaults to FRONTEND_URL + /reset-password when left empty.
PASSWORD_RESET_URL=

# ----- Payments -----
PAYMENT_EXPIRY_MINUTES=15
PAYMENT_REMINDER_MINUTES=10
# 'auto' (default): Midtrans when MIDTRANS_SERVER_KEY is set, offline beta
# gateway otherwise. Force with 'midtrans' or 'beta'.
PAYMENT_GATEWAY=auto
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SANDBOX=true
# Shared secret for the offline beta gateway's webhook (non-production only).
BETA_WEBHOOK_SECRET=

# ----- Operations -----
# Beta mode keeps optional services (Reverb provider, Midtrans auto-binding,
# smtp mail) off for lightweight local runs. Automatically disabled when
# APP_ENV=production.
STMS_BETA_MODE=true
# Cron scheduler toggle (seat release, booking expiry, pruning).
STMS_SCHEDULER_ENABLED=false
# Set false to skip idempotent seeding during start.sh deploys.
SEED_ON_DEPLOY=true
